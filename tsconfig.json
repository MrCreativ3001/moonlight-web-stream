{
  "compilerOptions": {
    "rootDir": "web",
    "outDir": "./dist",
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES6",
      "ES2020",
      "ESNext.Disposable"
    ],
    "strict": true,
    "esModuleInterop": true
  },
  "include": [
    "web/**/*"
  ],
}