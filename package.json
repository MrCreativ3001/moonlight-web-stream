{
  "name": "moonlight-web",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "watch": {
    "build-light": {
      "patterns": [
        "src",
        "web"
      ],
      "extensions": "ts,html,css,svg,png,rs",
      "ignore": "web/api_bindings.d.ts",
      "runOnChangeOnly": false
    }
  },
  "repository": {
    "url": "This is required for uniffi-bindgen-react-native"
  },
  "scripts": {
    "dev": "npm run generate-bindings && npm-watch build-light",
    "build": "npm run generate-bindings && npm run build-moonlight-common && npm run build-light",
    "build-light": "webpack",
    "generate-bindings": "cargo test export_bindings --package common",
    "build-moonlight-common": "npm run ubrn:checkout && npm run ubrn:build",
    "ubrn:checkout": "ubrn checkout",
    "ubrn:build": "ubrn build web"
  },
  "license": "GPL-3.0-or-later",
  "private": "true",
  "devDependencies": {
    "copy-webpack-plugin": "14.0.0",
    "cpx": "1.2.1",
    "css-loader": "7.1.4",
    "html-webpack-plugin": "5.6.7",
    "npm-watch": "0.13.0",
    "style-loader": "4.0.0",
    "ts-loader": "9.6.0",
    "typescript": "5.9.3",
    "uniffi-bindgen-react-native": "0.31.0-3",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3"
  }
}